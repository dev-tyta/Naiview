# Naiview Intelligence — Environment Variables
# -------------------------------------------------------
# For the HTML prototype: edit window.__NAIVIEW_CONFIG__ in frontend/env.js
# For the Vite production build: copy this file to .env and fill in values

# FastAPI backend base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Set to "false" when backend is live and stable
VITE_DEMO_MODE=true

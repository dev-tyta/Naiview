# ──────────────────────────────────────────────
# NaijaReview Intelligence — Environment Variables
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Gemini ───────────────────────────────────
GEMINI_API_KEY=AIza-xxxxx

# ─── LLM Model Configuration ─────────────────
GEMINI_GENERATION_MODEL=gemini-2.5-pro
GEMINI_UTILITY_MODEL=gemini-2.0-flash
LLM_MAX_RETRIES=2
LLM_DEFAULT_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# ─── Database ─────────────────────────────────
# SQLite for dev. Swap to postgres://user:pass@host/db for prod.
DATABASE_URL=sqlite:///./data/naijareview.db

# ─── Auth / JWT ───────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── ChromaDB ─────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=naijareview

# ─── FAISS ────────────────────────────────────
FAISS_INDEX_PATH=./data/processed/faiss_index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Redis (Fingerprint Cache) ────────────────
REDIS_URL=redis://localhost:6379/0
FINGERPRINT_CACHE_TTL_HOURS=24
# Set to "memory" for local dev without Redis
CACHE_BACKEND=memory

# ─── API Server ───────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
LOG_LEVEL=DEBUG

# ─── Vibe Checker Thresholds ──────────────────
VIBE_REGEN_THRESHOLD=0.70
VIBE_MAX_RETRIES=2

# ─── Retrieval ────────────────────────────────
RETRIEVAL_TOP_K=20
BM25_WEIGHT=0.4
SEMANTIC_WEIGHT=0.6

# ─── Evaluation ───────────────────────────────
EVAL_SAMPLE_SIZE=1000
EVAL_SEED=42
RESULTS_DIR=./results

# ─── Confidence Thresholds ────────────────────
TASK_B_CONFIDENCE_THRESHOLD=0.75
MIN_DIVERSITY_SCORE=0.6
MIN_HISTORY_FOR_FINGERPRINT=3

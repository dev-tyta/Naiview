# ──────────────────────────────────────────────
# NaijaReview Intelligence — .gitignore
# ──────────────────────────────────────────────

# ─── Python ──────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.manifest
*.spec

# ─── Virtual environments ────────────────────
.env
.venv/
venv/
env/
ENV/

# ─── IDE ─────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Testing ─────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml

# ─── Type checking ───────────────────────────
.mypy_cache/
.dmypy.json
.pytype/
.ruff_cache/

# ─── Data (raw + processed are NOT committed) ─
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/chroma/

# ─── Results (generated at eval time) ────────
results/*
!results/.gitkeep

# ─── Docker ──────────────────────────────────
docker-compose.override.yml

# ─── OS ──────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Jupyter ─────────────────────────────────
.ipynb_checkpoints/

# ─── Redis ───────────────────────────────────
*.rdb
*.aof

# ─── Logs ────────────────────────────────────
*.log

# ─── Misc ────────────────────────────────────
tempCodeRunnerFile.py
.streamlit/secrets.toml

# ─── Frontend ────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
